# =============================================================================
# Meridian API Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
# =============================================================================

# Environment
ENVIRONMENT=development
DEBUG=false

# =============================================================================
# REQUIRED IN PRODUCTION - Must be set when ENVIRONMENT=production
# =============================================================================

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT Secret - Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=generate-a-secure-random-string-for-production

# =============================================================================
# OPTIONAL - AI & Notifications
# =============================================================================

# Anthropic API Key (for AI analysis features)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Resend Email API Key
# Get from: https://resend.com/api-keys
RESEND_API_KEY=
FROM_EMAIL=Drishti <alerts@yourdomain.com>

# =============================================================================
# OPTIONAL - Stripe Payments
# =============================================================================

# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# OPTIONAL - Monitoring
# =============================================================================

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/your-org/projects/your-project/keys/
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins. DO NOT use "*" in production!
# Examples:
#   Single origin: http://localhost:3000
#   Multiple: http://localhost:3000,https://app.example.com
# NEVER use "*" when allow_credentials=True (which is the default)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
